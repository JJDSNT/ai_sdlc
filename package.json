{
  "name": "ai_sdlc",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "dev": "concurrently -n opencode,apps -c cyan,green \"pnpm dev:opencode\" \"pnpm dev:apps\"",
    "dev:apps": "wait-on tcp:4096 && pnpm -r --parallel --filter './apps/*' run dev",
    "dev:opencode": "opencode serve --port 4096",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r exec rm -rf node_modules dist .next"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "wait-on": "^9.0.4"
  }
}